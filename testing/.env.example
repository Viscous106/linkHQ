# ── Zoom Meeting SDK (client join signature) ──────────────────────────────
# Marketplace → your Meeting SDK app → App Credentials
ZOOM_SDK_KEY=
ZOOM_SDK_SECRET=

# ── Zoom Webhooks ─────────────────────────────────────────────────────────
# Marketplace → your app → Feature → Event Subscriptions → Secret Token
ZOOM_WEBHOOK_SECRET_TOKEN=

# ── Zoom Server-to-Server OAuth (Reports API + recording download) ────────
# A separate Server-to-Server OAuth app. Scopes: report:read:admin,
# cloud_recording:read:admin (or granular equivalents).
ZOOM_S2S_ACCOUNT_ID=
ZOOM_S2S_CLIENT_ID=
ZOOM_S2S_CLIENT_SECRET=

# ── AWS S3 + CloudFront (recording storage & signed playback) ─────────────
AWS_REGION=
S3_BUCKET=
CLOUDFRONT_DOMAIN=
CLOUDFRONT_KEY_PAIR_ID=
# PEM private key for the CloudFront key group. Use \n for newlines on one line,
# or point CLOUDFRONT_PRIVATE_KEY_FILE at a file path instead.
CLOUDFRONT_PRIVATE_KEY=
CLOUDFRONT_PRIVATE_KEY_FILE=

# ── App ───────────────────────────────────────────────────────────────────
PORT=4000
DATABASE_URL=./data/app.sqlite
SESSION_SECRET=
# Comma-separated allowed origins for CORS (frontend dev server)
CORS_ORIGIN=http://localhost:5173
